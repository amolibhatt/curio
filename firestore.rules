rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /pairings/{pairingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.user1Id == request.auth.uid;
      allow update: if request.auth != null
        && (
          (resource.data.user2Id == null && request.resource.data.user2Id == request.auth.uid)
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['anniversaryDate'])
              && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid))
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['user1Id'])
              && request.resource.data.user1Id == request.auth.uid)
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['user2Id'])
              && request.resource.data.user2Id == request.auth.uid)
        );
      allow delete: if false;
    }

    match /facts/{factId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.authorId == request.auth.uid
            || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authorId'])
                && request.resource.data.authorId == request.auth.uid));
      allow delete: if false;

      match /reactions/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /dailyAnswers/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.pairingId is string;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['answers']);
      allow delete: if false;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function getUserPairingId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.pairingId;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['name', 'avatar', 'pairingId'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 50
        && request.resource.data.avatar is string
        && request.resource.data.pairingId is string;
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'avatar'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 50
        && request.resource.data.avatar is string;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /pairings/{pairingId} {
      allow read: if request.auth != null
        && (resource.data.user1Id == request.auth.uid
            || resource.data.user2Id == request.auth.uid
            || resource.data.user2Id == null
            || getUserPairingId() == pairingId);
      allow create: if request.auth != null
        && request.resource.data.user1Id == request.auth.uid
        && request.resource.data.user2Id == null
        && request.resource.data.inviteCode is string
        && request.resource.data.inviteCode.size() > 0
        && request.resource.data.inviteCode.size() <= 32
        && request.resource.data.keys().hasOnly(['inviteCode', 'user1Id', 'user2Id']);
      allow update: if request.auth != null
        && (
          (resource.data.user2Id == null
            && request.resource.data.user2Id == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['user2Id']))
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['anniversaryDate'])
              && (resource.data.user1Id == request.auth.uid || resource.data.user2Id == request.auth.uid)
              && request.resource.data.anniversaryDate is string
              && request.resource.data.anniversaryDate.size() == 10)
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['user1Id'])
              && request.resource.data.user1Id == request.auth.uid
              && resource.data.user2Id != request.auth.uid)
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['user2Id'])
              && request.resource.data.user2Id == request.auth.uid
              && resource.data.user1Id != request.auth.uid)
        );
      allow delete: if false;
    }

    match /facts/{factId} {
      allow read: if request.auth != null
        && getUserPairingId() == resource.data.pairingId;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.pairingId == getUserPairingId()
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 5000
        && request.resource.data.date is string
        && request.resource.data.date.size() == 10
        && request.resource.data.categories is list
        && request.resource.data.categories.size() > 0
        && request.resource.data.categories.size() <= 7
        && request.resource.data.keys().hasOnly(['text', 'authorId', 'pairingId', 'date', 'categories']);
      allow update: if request.auth != null
        && ((resource.data.authorId == request.auth.uid
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'categories'])
             && request.resource.data.text is string
             && request.resource.data.text.size() > 0
             && request.resource.data.text.size() <= 5000
             && request.resource.data.categories is list
             && request.resource.data.categories.size() > 0
             && request.resource.data.categories.size() <= 7)
            || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authorId'])
                && request.resource.data.authorId == request.auth.uid
                && resource.data.pairingId == getUserPairingId()
                && resource.data.authorId != get(/databases/$(database)/documents/pairings/$(resource.data.pairingId)).data.user1Id
                && resource.data.authorId != get(/databases/$(database)/documents/pairings/$(resource.data.pairingId)).data.user2Id));
      allow delete: if false;

      match /reactions/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (
            (request.auth.uid == userId
              && (request.method == 'delete'
                  || (request.resource.data.keys().hasOnly(['type'])
                      && request.resource.data.type is string
                      && request.resource.data.type in ['mind-blown', 'fascinating', 'heart', 'laugh', 'thinking', 'sad'])))
            || (request.method == 'delete'
                && getUserPairingId() == get(/databases/$(database)/documents/facts/$(factId)).data.pairingId
                && userId != get(/databases/$(database)/documents/pairings/$(getUserPairingId())).data.user1Id
                && userId != get(/databases/$(database)/documents/pairings/$(getUserPairingId())).data.user2Id)
          );
      }
    }

    match /dailyAnswers/{docId} {
      allow read: if request.auth != null
        && getUserPairingId() == resource.data.pairingId;
      allow create: if request.auth != null
        && request.resource.data.pairingId == getUserPairingId()
        && request.resource.data.answers.keys().hasOnly([request.auth.uid])
        && request.resource.data.answers[request.auth.uid] is string
        && request.resource.data.answers[request.auth.uid].size() > 0
        && request.resource.data.answers[request.auth.uid].size() <= 2000
        && request.resource.data.date is string
        && request.resource.data.questionText is string
        && request.resource.data.category is string
        && request.resource.data.keys().hasOnly(['pairingId', 'date', 'questionText', 'category', 'answers']);
      allow update: if request.auth != null
        && getUserPairingId() == resource.data.pairingId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['answers'])
        && request.resource.data.answers[request.auth.uid] is string
        && request.resource.data.answers[request.auth.uid].size() > 0
        && request.resource.data.answers[request.auth.uid].size() <= 2000;
      allow delete: if false;

      match /reactions/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.auth.uid == userId
          && (request.method == 'delete'
              || (request.resource.data.keys().hasOnly(['type'])
                  && request.resource.data.type is string
                  && request.resource.data.type in ['mind-blown', 'fascinating', 'heart', 'laugh', 'thinking', 'sad']));
      }
    }
  }
}
